# Copy this file to .env.local and fill in from your Supabase project:
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, never expose in the browser. Used by game API routes + seed script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Set to false to close new signups (existing accounts can still log in)
NEXT_PUBLIC_REGISTRATION_AVAILABLE=true
